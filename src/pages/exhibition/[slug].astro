---
import Layout from "@/layouts/Layout.astro";
import ExhibitionGallery from "@/views/ExhibitionGallery";
import { exhibitions } from "@/data/exhibitions";

export function getStaticPaths() {
  return exhibitions.map((exhibition) => ({
    params: { slug: exhibition.slug },
    props: { exhibition },
  }));
}

const { exhibition } = Astro.props;
---

<Layout
  title={`${exhibition.title} | Leroy Brothers`}
  description={exhibition.location ? `${exhibition.title} — ${exhibition.location}` : exhibition.title}
  ogImage={exhibition.coverImage}
>
  <ExhibitionGallery slug={exhibition.slug} client:load />
</Layout>
