---
const destinations = [
  {
    title: "Leroy Brothers",
    description: "Belgian contemporary art collective. Active since 1997.",
    buttonText: "Explore the Art",
    href: "/art",
    isExternal: false,
  },
  {
    title: "Toile Blanche",
    description: "A functioning hotel in Saint-Paul-de-Vence operating as a durational artwork.",
    buttonText: "Book a stay",
    href: "https://www.toileblanche.com",
    isExternal: true,
  },
  {
    title: "TB Contemporary",
    description: "On-site exhibition space and sculpture park.",
    buttonText: "View programme",
    href: "https://www.toileblanchecontemporary.com",
    isExternal: true,
  },
];
---

<div class="min-h-screen bg-background flex flex-col">
  <section class="flex-1 flex flex-col justify-center px-6 md:px-12 lg:px-24 py-24 md:py-32">
    <div class="max-w-6xl mx-auto w-full">
      <div class="mb-12 md:mb-16">
        <img
          src="/images/logo-leroy-brothers-64.png"
          srcset="/images/logo-leroy-brothers-48.png 48w, /images/logo-leroy-brothers-64.png 64w"
          sizes="(min-width: 768px) 64px, 48px"
          alt="Leroy Brothers"
          width={64}
          height={64}
          fetchpriority="high"
          class="w-12 h-12 md:w-16 md:h-16 object-contain"
        />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-20 md:mb-32">
        {destinations.map((destination) => (
          <div class="group">
            <div class="border-t border-border pt-8">
              <h2 class="font-display text-2xl md:text-3xl font-bold mb-4 tracking-tight uppercase">
                {destination.title}
              </h2>
              <p class="text-muted-foreground leading-relaxed mb-8 min-h-[120px] font-serif">
                {destination.description}
              </p>
              <a
                href={destination.href}
                class="btn-museum inline-flex items-center group/btn"
                target={destination.isExternal ? "_blank" : undefined}
                rel={destination.isExternal ? "noopener noreferrer" : undefined}
              >
                <span class="font-serif">{destination.buttonText}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 transition-transform group-hover/btn:translate-x-1">
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <footer class="px-6 md:px-12 lg:px-24 py-8 border-t border-border">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
        © {new Date().getFullYear()} Leroy Brothers
      </p>
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
        Saint-Paul-de-Vence, France
      </p>
    </div>
  </footer>
</div>
