---
import ProjectCard from "@/components/ProjectCard.astro";
import { getProjectsByYear } from "@/data/projects";

const allProjects = getProjectsByYear();
const projectsByDecade = allProjects.reduce((acc, project) => {
  const decade = Math.floor(parseInt(project.year) / 10) * 10;
  if (!acc[decade]) acc[decade] = [];
  acc[decade].push(project);
  return acc;
}, {} as Record<number, typeof allProjects>);
const decades = Object.keys(projectsByDecade).map(Number).sort((a, b) => b - a);
---

<section class="relative min-h-screen flex flex-col justify-end px-6 md:px-12 pb-24 md:pb-32">
  <div class="max-w-content mx-auto w-full relative">
    <div class="max-w-5xl animate-fade-in">
      <div class="flex items-center gap-4 mb-8 animate-fade-in-up" style="animation-delay: 100ms">
        <img
          src="/images/logo-leroy-brothers-48.png"
          srcset="/images/logo-leroy-brothers-40.png 40w, /images/logo-leroy-brothers-48.png 48w"
          sizes="(min-width: 768px) 48px, 40px"
          alt="Leroy Brothers"
          width={48}
          height={48}
          fetchpriority="high"
          class="block w-10 h-10 md:w-12 md:h-12 object-contain"
        />
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground text-left leading-none">
          Contemporary Art Collective — Est. 1997
        </p>
      </div>
      <h1 class="font-display text-6xl md:text-8xl lg:text-[10rem] font-black leading-[0.85] uppercase mb-12 text-left animate-fade-in-up" style="letter-spacing: -0.06em; animation-delay: 200ms">
        Leroy<br />
        Brothers
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mb-16 leading-relaxed text-left animate-fade-in-up" style="animation-delay: 300ms">
        Leroy Brothers — Archive. Work produced between 1997 and the present. Organized chronologically.
      </p>
      <div class="text-left animate-fade-in-up" style="animation-delay: 400ms">
        <a href="#archive" class="btn-museum inline-flex items-center group">
          <span>Enter The Archive</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 transition-transform group-hover:translate-y-1">
            <path d="M12 5v14" />
            <path d="m19 12-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
  <div class="absolute bottom-8 right-6 md:right-12 animate-fade-in" style="animation-delay: 600ms">
    <div class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground writing-vertical">
      Scroll to explore
    </div>
  </div>
</section>

<section id="archive" class="px-6 md:px-12 py-24 md:py-40">
  <div class="max-w-content mx-auto">
    <div class="mb-24 md:mb-32">
      <span class="font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground block mb-4">
        01 — The Archive
      </span>
      <h2 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight">
        All Projects
      </h2>
    </div>

    <div class="relative">
      {decades.map((decade, decadeIndex) => (
        <div class="mb-32 md:mb-48 last:mb-0">
          <div class="sticky top-20 md:top-24 z-10 bg-background py-6 mb-16 md:mb-24">
            <div class="flex items-baseline gap-4">
              <span class="font-mono text-xs text-muted-foreground uppercase tracking-[0.3em]">
                {decadeIndex === 0 ? "Recent" : "Archive"}
              </span>
              <h3 class="font-display text-7xl md:text-9xl font-black text-foreground/10 tracking-tighter">
                {decade}s
              </h3>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-20 md:gap-y-32">
            {projectsByDecade[decade].map((project, index) => (
              <ProjectCard project={project} index={index} />
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="px-6 md:px-12 py-32 md:py-48 border-t border-border">
  <div class="max-w-content mx-auto">
    <div class="max-w-4xl">
      <span class="font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground block mb-8">
        Collaboration
      </span>
      <h2 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-8">
        Let's create something together
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl mb-12">
        Interested in exhibitions, commissions, or collaborative projects?
        We're always exploring new territories.
      </p>
      <a href="mailto:nicolas@leroybrothers.com" class="btn-museum">
        Get in Touch
      </a>
    </div>
  </div>
</section>
